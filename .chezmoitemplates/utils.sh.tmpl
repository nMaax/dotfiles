# utils.sh

# --- Color Definitions ---
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

# --- Helper Logging Functions ---
info() { echo -e "${BLUE}==>${NC} $1"; }
success() { echo -e "${GREEN}==>${NC} $1"; }
warn() { echo -e "${YELLOW}==>${NC} $1"; }
error() { echo -e "${RED}==>${NC} $1"; }

# --- User Prompting ---
# ask <question>
# Prints "<question> [Y/n] " and reads user input.
# Returns 0 (true) for Y / y / <Enter>, non-zero (false) for anything else.
ask() {
  local answer
  read -rp "$1 [Y/n] " answer
  [[ "${answer,,}" == "y" || -z "$answer" ]]
}

# --- Persistent Note Handling ---
# We use a temp file to share notes across different script processes
NOTES_FILE="/tmp/dotfiles_install_notes.txt"

add_note() {
  echo -e "$1\n" >>"$NOTES_FILE"
}

show_notes() {
  if [[ -f "$NOTES_FILE" ]]; then
    info "Post-Install Summary:"
    cat "$NOTES_FILE"
    echo ""

    # Resolve Documents dir once
    local docs_dir
    if command -v xdg-user-dir >/dev/null 2>&1; then
      docs_dir="$(xdg-user-dir DOCUMENTS)"
    elif [[ -f "$HOME/.config/user-dirs.dirs" ]]; then
      docs_dir="$(. "$HOME/.config/user-dirs.dirs" 2>/dev/null; echo "${XDG_DOCUMENTS_DIR:-$HOME/Documents}")"
    else
      docs_dir="$HOME/Documents"
    fi

    # If a notes file from a previous install already exists, skip saving
    if compgen -G "${docs_dir}/dotfiles_install_notes_*.md" >/dev/null 2>&1; then
      warn "A notes file from a previous install already exists in $docs_dir — skipping save."
    elif ask "💾 Save these notes as Markdown to your Documents folder?"; then
      local timestamp out_file
      timestamp=$(date +"%Y%m%d_%H%M%S")
      out_file="${docs_dir}/dotfiles_install_notes_${timestamp}.md"
      mkdir -p "$docs_dir"
      {
        echo "# Dotfiles Install Notes"
        echo ""
        echo "_Generated: $(date)_"
        echo ""
        cat "$NOTES_FILE"
      } >"$out_file"
      success "Notes saved to $out_file"
    fi

    rm -f "$NOTES_FILE"
  fi
}

clean_notes() {
  if [[ -f "$NOTES_FILE" ]]; then
    info "Cleaning up notes:"
    : >"$NOTES_FILE"
  fi
}

# --- GPU Detection ---
# Sets GPU_VENDOR to "nvidia", "amd", or "" (unknown).
# Runs lspci once and caches the result.
GPU_VENDOR=""
detect_gpu_vendor() {
  local gpu_info
  gpu_info="$(lspci | grep -iE 'vga|3d|display')"
  if echo "$gpu_info" | grep -iq 'nvidia'; then
    GPU_VENDOR="nvidia"
  elif echo "$gpu_info" | grep -iqE 'amd|radeon'; then
    GPU_VENDOR="amd"
  else
    GPU_VENDOR=""
  fi
}
