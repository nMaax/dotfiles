# utils.sh

# --- Color Definitions ---
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m'

# --- Helper Logging Functions ---
info() { echo -e "${BLUE}==>${NC} $1"; }
success() { echo -e "${GREEN}==>${NC} $1"; }
warn() { echo -e "${YELLOW}==>${NC} $1"; }
error() { echo -e "${RED}==>${NC} $1"; }

# --- User Prompting ---
# ask <question>
# Prints "<question> [Y/n] " and reads user input.
# Returns 0 (true) for Y / y / <Enter>, non-zero (false) for anything else.
ask() {
  local answer
  read -rp "$1 [Y/n] " answer
  [[ "${answer,,}" == "y" || -z "$answer" ]]
}

reset_chezmoi_data_secret() {
  local key="$1"
  local reminder="$2"
  local config_file="${XDG_CONFIG_HOME:-$HOME/.config}/chezmoi/chezmoi.toml"

  if [[ ! -f "$config_file" ]]; then
    warn "Could not find $config_file. Please remove '$key' manually from your chezmoi.toml."
    return
  fi

  if ! grep -qE "^[[:space:]]*${key}[[:space:]]*=" "$config_file"; then
    warn "Could not find '$key' in $config_file. Skipping cleanup."
    return
  fi

  local tmp_file
  tmp_file="$(mktemp)"

  if ! awk -v key="$key" -v reminder="$reminder" '
    BEGIN { updated=0 }
    {
      if ($0 ~ "^[[:space:]]*" key "[[:space:]]*=") {
        match($0, /^[[:space:]]*/)
        print substr($0, RSTART, RLENGTH) key " = \"\" # " reminder
        updated=1
      } else {
        print
      }
    }
    END { exit(updated ? 0 : 1) }
  ' "$config_file" >"$tmp_file"; then
    rm -f "$tmp_file"
    warn "Failed to update '$key' in $config_file."
    return
  fi

  mv "$tmp_file" "$config_file"
  success "Removed '$key' from $config_file."
}

# --- GPU Detection ---
# Sets GPU_VENDOR to "nvidia", "amd", or "" (unknown).
# Runs lspci once and caches the result.
GPU_VENDOR=""
detect_gpu_vendor() {
  local gpu_info
  gpu_info="$(lspci | grep -iE 'vga|3d|display')"
  if echo "$gpu_info" | grep -iq 'nvidia'; then
    GPU_VENDOR="nvidia"
  elif echo "$gpu_info" | grep -iqE 'amd|radeon'; then
    GPU_VENDOR="amd"
  else
    GPU_VENDOR=""
  fi
}
