## --- GAMING SHADER SIZING ---
.config/environment.d/gaming.conf

# --- FISH: Exclude shell state ---
.config/fish/fish_variables

# --- GHOSTTY: Exclude noctalia-managed theme and unused shaders ---
.config/ghostty/themes/**
.config/ghostty/shaders/*
!.config/ghostty/shaders/cursor_warp.glsl

# --- HYPR: Exclude noctalia-managed theme ---
.config/hypr/noctalia/**

# --- NOCTALIA: Exclude generated files, include only used colorschemes ---
.config/noctalia/plugins/**
.config/noctalia/colors.json
.config/noctalia/colorschemes/*
!.config/noctalia/colorschemes/Rosey\ AMOLED
!.config/noctalia/colorschemes/Lilac\ AMOLED
!.config/noctalia/colorschemes/Velvet\ AMOLED
!.config/noctalia/colorschemes/Cyberpunk
!.config/noctalia/colorschemes/Velvet\ AMOLED
!.config/noctalia/colorschemes/Cyberpunk
!.config/noctalia/colorschemes/Occult\ Umbral

# --- NVIM: Exclude matugen-generated theme ---
.config/nvim/lua/matugen.lua

# --- ELECTRON APPS ---
!.config/Element
.config/Element/*
!.config/Element/electron-config.json

!.config/Code
.config/Code/*
!.config/Code/argv.json

!.config/Code - OSS
.config/Code - OSS/*
!.config/Code - OSS/argv.json

!.config/chromium-flags.conf

# --- OPENRGB: Exclude everything except sora-pattern ---
.config/OpenRGB/**
!.config/OpenRGB/plugins/
!.config/OpenRGB/plugins/settings/
!.config/OpenRGB/plugins/settings/effect-patterns/
!.config/OpenRGB/plugins/settings/effect-patterns/CustomGradientWave/
!.config/OpenRGB/plugins/settings/effect-patterns/CustomGradientWave/sora-pattern

# --- LOCAL ---
.local/*
!.local/bin/
!.local/share
.local/share/*
!.local/share/applications
.local/share/applications/*
!.local/share/applications/code.desktop
!.local/share/applications/io.element.Element.desktop
