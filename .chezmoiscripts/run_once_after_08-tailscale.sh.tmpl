#!/bin/bash
set -euo pipefail

{{ template "utils.sh.tmpl" . }}
{{ template "external_links.sh.tmpl" . }}

echo ""
info "🌐 [Tailscale] Starting..."
echo ""

info "📡 Installing Tailscale..."
sudo pacman -S --noconfirm --needed tailscale

info "Enabling Tailscale daemon..."
sudo systemctl enable --now tailscaled
sleep 2

{{- if .tailscale_authkey }}
info "Authenticating Tailscale using provided authkey..."
if sudo tailscale status 2>/dev/null | grep -qE "^[0-9]+\.[0-9]"; then
  success "Tailscale already connected. Skipping."
else
  sudo tailscale up --ssh --authkey="{{ .tailscale_authkey }}"
  success "Tailscale connected successfully."
fi

if ask "🧹 Remove 'tailscale_authkey' from ~/.config/chezmoi/chezmoi.toml now? (under [data], set tailscale_authkey = \"\")"; then
  reset_chezmoi_data_secret "tailscale_authkey" "Leave \"\" if you want to skip tailscale"
fi
{{- else }}
warn "No 'tailscale_authkey' found in chezmoi.toml. Skipping auto-login."
{{- end }}

echo ""
success "✅ [Tailscale] Done."
echo ""
