#!/bin/bash
set -euo pipefail

{{ template "utils.sh.tmpl" . }}
{{ template "external_links.sh.tmpl" . }}

# For the future: move to shelly when it becomes default in CachyOS

{{- if ne .chezmoi.osRelease.id "cachyos" }}
echo "This script is intended to run on CachyOS."
echo "Did nothing, will close now."
exit 1
{{- end }}

echo ""
info "📦 [Stage 1] Installing prerequisites..."
echo ""

clean_notes

read -rp "Did you tweak CachyOS as you like? [Y/n] " answer
if [[ "${answer,,}" != "y" && -n "$answer" ]]; then
  error "Go back and tune whatever you like using Cachy Hello. Closing, come back later."
  exit 1
fi

read -rp "Did you place the chezmoi.toml? [Y/n] " answer
if [[ "${answer,,}" != "y" && -n "$answer" ]]; then
  error "Please place the chezmoi.toml in its proper location before proceeding. Closing, come back later."
  exit 1
fi

info "🔄 Checking for cachy-update..."
if sudo pacman -Q cachy-update &>/dev/null; then
  cachy-update
else
  warn "cachy-update is not installed."
  warn "Did you really listen to me before??"
  warn "Please open 'CachyOS Hello' to enable cachy-update, and remind to tweak your system!"
fi

info "📦 Checking for missing base packages..."
BASE_PACKAGES=(binutils base-devel git vim cmake cpio appmenu-gtk-module libdbusmenu-glib hyprland xdg-desktop-portal-hyprland ddcutil)
for pkg in "${BASE_PACKAGES[@]}"; do
  if ! pacman -Qi "$pkg" &>/dev/null; then
    info "    Installing missing package: $pkg"
    sudo pacman -S --needed --noconfirm "$pkg"
  fi
done

info "🔧 Installing other utilities..."
sudo pacman -S --needed --noconfirm smartmontools ffmpeg imagemagick perl-image-exiftool jq texlive-latex glow dust bat ripgrep fd btop nvtop trash-cli transmission-cli ghostscript pandoc poppler qpdf ufw tldr ksshaskpass fzf zoxide
paru -S --needed --noconfirm caligula-bin pandoc-bin pdfcpu-bin ocrmypdf tesseract-data-eng tesseract-data-ita

echo ""
success "✅ [Stage 1] Prerequisites installed."
echo ""

echo ""
success "💤 [Stage 2] Installing apps and Noctalia..."
echo ""

GIT_NAME={{ .name | quote }}
GIT_EMAIL={{ .email | quote }}

info "🐙 Setting Git identity from config..."
git config --global user.name "$GIT_NAME"
git config --global user.email "$GIT_EMAIL"
info "Git identity set: $GIT_NAME <$GIT_EMAIL>"

info "🤓 Installing Nerd Fonts..."
sudo pacman -S --needed --noconfirm ttf-jetbrains-mono-nerd ttf-iosevka-nerd ttf-cascadia-code-nerd
info "🍎 Installing Apple Fonts..."
paru -S --needed --noconfirm apple-fonts

# Install Apple Emoji
EMOJI_FILE="/tmp/ttf-apple-emoji.pkg.tar.zst"

if ! pacman -Qs ttf-apple-emoji >/dev/null; then
  info "📥 Downloading verified Apple Emoji package..."
  curl -L "$APPLE_EMOJI_URL" -o "$EMOJI_FILE"

  # Verify hash before installing, since this is not taken from pacman repo or AUR
  if echo "$APPLE_EMOJI_SHA256  $EMOJI_FILE" | sha256sum -c -; then
    sudo pacman -U --noconfirm "$EMOJI_FILE"
    success "Apple Emoji installed successfully."
  else
    error "SHA256 checksum mismatch for Apple Emoji! Aborting font installation."
  fi
  rm -f "$EMOJI_FILE"
else
  success "Apple Emoji is already installed."
fi

info "🌊 Installing browsers..."
sudo pacman -S --needed --noconfirm chromium
paru -S --needed --noconfirm zen-browser-bin

info "🔗 Installing Telegram"
sudo pacman -S --needed --noconfirm telegram-desktop

info "🪐 Installing Starship..."
sudo pacman -S --needed --noconfirm starship

info "🐍 Installing tools for coding.."
sudo pacman -S --needed --noconfirm uv lazygit neovim nodejs jdk-openjdk
paru -S --needed --noconfirm visual-studio-code-bin

# ── AI TOOLS ──────────────────────────────────────────────────────────────────
info "🤖 Installing AI tools..."

# Detect GPU manufacturer
detect_gpu_vendor
if [ -z "$GPU_VENDOR" ]; then
  warn "Could not detect NVIDIA or AMD GPU. AI tools will run in CPU-only mode."
fi

# Install GPU-specific compute libraries / drivers
if [ "$GPU_VENDOR" = "nvidia" ]; then
  info "🟢 NVIDIA GPU detected. Installing CUDA toolkit for AI acceleration..."
  sudo pacman -S --needed --noconfirm cuda cudnn
elif [ "$GPU_VENDOR" = "amd" ]; then
  info "🔴 AMD GPU detected. Installing ROCm/HIP for AI acceleration..."
  sudo pacman -S --needed --noconfirm rocm-opencl-runtime rocm-hip-sdk hip-runtime-amd
fi

# Always install Gemini CLI
info "💎 Installing Gemini CLI..."
sudo pacman -S --needed --noconfirm gemini-cli

# Install llama.cpp with the right GPU backend
info "🦙 Installing llama.cpp..."
if [ "$GPU_VENDOR" = "nvidia" ]; then
  paru -S --needed --noconfirm llama-cpp-cuda
elif [ "$GPU_VENDOR" = "amd" ]; then
  paru -S --needed --noconfirm llama-cpp-hipblas
else
  paru -S --needed --noconfirm llama-cpp
fi

success "AI tools installed."
# ── END AI TOOLS ──────────────────────────────────────────────────────────────

info "📤 Installing LocalSend..."
paru -S --needed --noconfirm localsend

info "🔑 Installing KeePassXC..."
sudo pacman -S --needed --noconfirm keepassxc

info "☁️ Installing MEGA CMD..."
paru -S --needed --noconfirm megacmd-bin

info "🔬 Installing Element..."
sudo pacman -S --needed --noconfirm element-desktop

info "🎧 Installing Spotify (spicetify) from AUR..."
paru -S --needed --noconfirm spotify spicetify-cli

info "Setting up Spicetify..."
sudo chmod a+wr /opt/spotify
sudo chmod a+wr /opt/spotify/Apps -R
spicetify backup apply || spicetify apply

SPICETIFY_CONFIG_DIR="$HOME/.config/spicetify"
SPICETIFY_THEMES_DIR="$SPICETIFY_CONFIG_DIR/Themes"
COMFY_DIR="$SPICETIFY_THEMES_DIR/Comfy"
MARKETPLACE_DIR="$SPICETIFY_CONFIG_DIR/CustomApps/marketplace"

if [ ! -d "$COMFY_DIR" ]; then
  info "Installing Comfy theme for Spicetify..."
  cd "$SPICETIFY_THEMES_DIR"
  git clone "$SPICETIFY_COMFY_REPO" ComfyRepo
  mv ./ComfyRepo/Comfy/ ./
  rm -rf ./ComfyRepo/
  spicetify config current_theme Comfy color_scheme Comfy
  spicetify config inject_css 1 replace_colors 1 overwrite_assets 1 inject_theme_js 1
  spicetify apply
  success "Comfy theme installed and applied."
else
  info "Comfy theme already present, skipping."
fi

info "Installing Spicetify Marketplace...  (⚠️ not really the Arch way, but it doesnt touch anything outside home/)"
if [ ! -d "$MARKETPLACE_DIR" ] || [ -z "$(ls -A "$MARKETPLACE_DIR")" ]; then
  curl -fsSL "$SPICETIFY_MARKETPLACE_INSTALL_URL" | sh
else
  success "Spicetify Marketplace already installed, skipping."
fi

info "👾 Installing Discord (Equicord + OpenAsar) from AUR..."
paru -S --needed --noconfirm discord equicord-installer-bin

sudo Equilotl -install -location /opt/discord
sudo Equilotl -install-openasar -location /opt/discord

paru -Rns --noconfirm equicord-installer-bin || true

info "🎵 Installing EasyEffects..."
sudo pacman -S --needed --noconfirm easyeffects lsp-plugins

info "🌙 Installing Noctalia dependencies..."
paru -S --needed --noconfirm cliphist wlsunset xdg-desktop-portal evolution-data-server hyprshot quickshell-overview-git

kwallet_fresh=0
if ! pacman -Qs kwallet &>/dev/null; then
  kwallet_fresh=1
fi

echo "🖥️ Installing KDE suite, Qt, GTK and utility apps..."
sudo pacman -S --needed --noconfirm \
  qt6ct-kde qt5ct adw-gtk-theme nwg-look \
  qt6-multimedia archlinux-xdg-menu ark dolphin-plugins filelight \
  okular haruna kwrite gwenview \
  kwallet kwallet-pam

if [ "$kwallet_fresh" -eq 1 ]; then
  add_note "[KWALLET]: When prompted by an app, make a new wallet named kdewallet and bowfish encryption, using the same password as the user to enable automatic keyring login.\n See https://wiki.archlinux.org/title/KDE_Wallet for more information.\n Look at https://www.electronjs.org/docs/latest/api/safe-storage for Electron-specific information"
fi

echo "Syncing GTK with Noctalia and removing decorations..."
gsettings set org.gnome.desktop.interface gtk-theme 'adw-gtk3'
gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark'
gsettings set org.gnome.desktop.wm.preferences button-layout ':'

echo "🐬 Fixing Dolphin 'Open With' amnesia..."
sudo ln -sf /etc/xdg/menus/arch-applications.menu /etc/xdg/menus/applications.menu
rm -rf ~/.cache/ksycoca6*
kbuildsycoca6 --noincremental

noctalia_fresh=0
if ! pacman -Qs noctalia-shell &>/dev/null; then
  noctalia_fresh=1
fi

info "🦉 Installing Noctalia..."
paru -S --needed --noconfirm noctalia-shell

if [ "$noctalia_fresh" -eq 1 ]; then
  add_note "[NOCTALIA] ddcutil was installed by default, which may introduce system instability with certain monitors; remove it eventually with: sudo pacman -Rns ddcutil"
  add_note "[NOCTALIA] All built-in app-theming you commonly use are pre-enabled by default (GTK, Qt, KColorScheme, Ghostty, Hyprland, btop, Spicetify, Telegram, Zen Browser, cava, Discord, VSCode). Remaining steps require manual in-app user interaction, view official noctalia documentation for your specific needs: https://docs.noctalia.dev/theming/basic-app-theming/"
fi

info "💅 Setting Hyprcursor..."

CURSOR_TMP="/tmp/hypr_Bibata-Modern-Classic"
CURSOR_ARCHIVE="$CURSOR_TMP.tar.gz"
CURSOR_DEST="$HOME/.local/share/icons/Bibata-Modern-Classic"

if [ ! -d "$CURSOR_DEST" ]; then
  cd /tmp
  curl -LO "$BIBATA_CURSOR_URL"
  tar -xzf hypr_Bibata-Modern-Classic.tar.gz
  if [ -d Bibata-Modern-Classic ]; then
    rm -rf "$CURSOR_DEST"
    mv Bibata-Modern-Classic "$CURSOR_DEST"
  fi
  rm -f hypr_Bibata-Modern-Classic.tar.gz
  hyprctl setcursor Bibata-Modern-Classic 24 # Enable now
else
  success "Hyprcursor already installed, skipping."
fi

info "💧 Setting hyprland plugins..."

if ! hyprpm list | grep -q dynamic-cursors; then
  hyprpm update
  hyprpm add "$HYPR_DYNAMIC_CURSORS_REPO"
  hyprpm enable dynamic-cursors
else
  success "hypr-dynamic-cursors plugin already installed and enabled, skipping."
fi

echo ""
success "✅ [Stage 2] Apps and Noctalia installed."
echo ""
