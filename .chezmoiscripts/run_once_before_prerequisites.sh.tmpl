#!/bin/bash
set -euo pipefail

{{ template "utils.sh.tmpl" . }}
{{ template "external_links.sh.tmpl" . }}

# For the future: move to shelly when it becomes default in CachyOS

{{- if ne .chezmoi.osRelease.id "cachyos" }}
error "This script is intended to run on CachyOS."
error "Did nothing, will close now."
exit 1
{{- end }}

echo ""
success "💤 [Stage 2] Installing apps..."
echo ""

info "🎧 Installing Spotify (spicetify) from AUR..."
warn "By default we will wipe anything related to spicetify first, to make a clean installation"

# Wipe the old Spicetify configuration and backups completely
rm -rf "$HOME/.config/spicetify"

# Force reinstall Spotify and Spicetify.
# Removing '--needed' ensures paru replaces any modified files in /opt/spotify 
# with fresh ones from your local package cache.
paru -S --noconfirm spotify spicetify-cli

info "Setting up Spicetify permissions..."
sudo chmod a+wr /opt/spotify
sudo chmod a+wr /opt/spotify/Apps -R

# Create the Spotify config directory and an empty prefs file
mkdir -p "$HOME/.config/spotify"
touch "$HOME/.config/spotify/prefs"

# Initialize Spicetify and point it to the prefs file
spicetify config prefs_path "$HOME/.config/spotify/prefs"

# Backup and apply
spicetify backup apply --no-restart

SPICETIFY_CONFIG_DIR="$HOME/.config/spicetify"
SPICETIFY_THEMES_DIR="$SPICETIFY_CONFIG_DIR/Themes"

# Install Comfy Theme
info "Installing Comfy theme for Spicetify..."
mkdir -p "$SPICETIFY_THEMES_DIR"
cd "$SPICETIFY_THEMES_DIR"
git clone "$SPICETIFY_COMFY_REPO" ComfyRepo
mv ./ComfyRepo/Comfy/ ./
rm -rf ./ComfyRepo/

spicetify config current_theme Comfy color_scheme Comfy
spicetify config inject_css 1 replace_colors 1 overwrite_assets 1 inject_theme_js 1
spicetify apply --no-restart

# Install Marketplace
info "Installing Spicetify Marketplace... (⚠️ not really the Arch way, but it doesnt touch anything outside home/)" 

# Download the script to a temporary file instead of piping it directly to sh
curl -fsSL "$SPICETIFY_MARKETPLACE_INSTALL_URL" -o /tmp/install_marketplace.sh

# Use 'sed' to find "spicetify apply" and replace it with "spicetify apply --no-restart"
sed -i 's/spicetify apply/spicetify apply --no-restart/g' /tmp/install_marketplace.sh

# Run our modified, silent version of the script
sh /tmp/install_marketplace.sh

# Clean up the temporary file
rm /tmp/install_marketplace.sh

success "Spotify, Spicetify, Comfy, and Marketplace cleanly installed!"

info "👾 Installing Discord (Equicord + OpenAsar) from AUR..."
paru -S --needed --noconfirm discord equicord-installer-bin

sudo Equilotl -install -location /opt/discord || success "Equicord already installed, skipping..."
sudo Equilotl -install-openasar -location /opt/discord || success "OpenAsar already installed, skipping..."

paru -Rns --noconfirm equicord-installer-bin || true

echo ""
success "✅ [Stage 2] Apps installed."
echo ""

echo ""
success "💤 [Stage 3] Installing Noctalia and Hyprland Extras..."
echo ""

info "🌙 Installing Noctalia dependencies..."
paru -S --needed --noconfirm cliphist wlsunset xdg-desktop-portal evolution-data-server hyprshot
add_note "[NOCTALIA] ddcutil was installed by default, which may introduce system instability with certain monitors; remove it eventually with: sudo pacman -Rns ddcutil"

info "🦉 Installing Noctalia..."
paru -S --needed --noconfirm noctalia-shell
add_note "[NOCTALIA] All built-in app-theming you commonly use are pre-enabled by default (GTK, Qt, KColorScheme, Ghostty, Hyprland, btop, Spicetify, Telegram, Zen Browser, cava, Discord, VSCode). Remaining steps require manual in-app user interaction, view official noctalia documentation for your specific needs: https://docs.noctalia.dev/theming/basic-app-theming/"

info "🔍 Installing Quickshell Overview..."
paru -S --needed --noconfirm quickshell-overview-git

info "🀄 Syncing GTK with Noctalia and removing decorations..."
gsettings set org.gnome.desktop.interface gtk-theme 'adw-gtk3'
gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark'
gsettings set org.gnome.desktop.wm.preferences button-layout ':'

info "💧 Setting hyprland plugins..."
if ! hyprpm list | grep -q dynamic-cursors; then
  hyprpm update
  hyprpm add "$HYPR_DYNAMIC_CURSORS_REPO"
  hyprpm enable dynamic-cursors
else
  success "hypr-dynamic-cursors plugin already installed and enabled, skipping."
fi

echo ""
success "✅ [Stage 3] Noctalia and Hyprland extras installed."
echo ""
