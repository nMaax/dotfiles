#!/bin/bash
set -euo pipefail

{{ template "utils.sh.tmpl" . }}
{{ template "external_links.sh.tmpl" . }}

{{- if ne .chezmoi.osRelease.id "cachyos" }}
error "This script is intended to run on CachyOS. But you are running it on $(
  . /etc/os-release
  echo "$NAME $VERSION"
)."
error "Please, use 🥮 dotfiles on CachyOS only."
exit 1
{{- end }}

{{ if .gaming -}}
success "🎮 Gaming flag is set. Applying optimizations..."

info "🛸 Installing Millennium..."
paru -S --needed --noconfirm millennium

info "🦚 Installing OpenRGB..."
sudo pacman -S --needed --noconfirm openrgb

info "🎎 Installing Wallpaper Engine compatibility layer..."
paru -S --needed --noconfirm linux-wallpaperengine

info "⛏️ Installing Minecraft (Prism-launcher and Java dependencies)..."
sudo pacman -S --needed --noconfirm prismlauncher
sudo pacman -S --needed --noconfirm jdk8-openjdk jdk17-openjdk jdk21-openjdk

info "🥭 Installing mango and mangojuice..."
sudo pacman -S --needed --noconfirm mangohud
paru -S --needed --noconfirm mangojuice

info "💓 Installing vrrtest..."
paru -S --needed --noconfirm vrrtest

info "📹 Installing OBS Plugins for game capture and streaming..."
paru -S --needed --noconfirm obs-vkcapture lib32-obs-vkcapture obs-pipewire-audio-capture-bin

if pacman -Q gamemode >/dev/null 2>&1; then
  info "Feral's gamemode detected. Checking for ananicy-cpp conflicts..."
  if systemctl is-enabled --quiet ananicy-cpp 2>/dev/null || systemctl is-active --quiet ananicy-cpp 2>/dev/null; then
    warn "Conflict detected: Disabling ananicy-cpp to prevent GameMode scheduling issues..."
    sudo systemctl disable --now ananicy-cpp
  else
    info "ananicy-cpp is not active. No conflicts."
  fi
else
  info "Feral's gamemode not installed. Skipping ananicy-cpp conflict check."
fi

info "[GAMING] Shader cache is configured via ~/.config/environment.d/gaming.conf."

info "[GAMING] Mouse acceleration is set to 'flat' in ~/.config/hypr/hyprland/input.conf."
info "[GAMING] Update the device 'name' there using \`hyprctl devices\`."

info "[GAMING] Steam launch options:"
info "  NVIDIA: PROTON_ENABLE_WAYLAND=1 PROTON_DLSS_UPGRADE=1 PROTON_NVIDIA_LIBS_NO_32BIT=1 PROTON_ENABLE_HDR=1 ENABLE_HDR_WSI=1 game-performance %command%"
info "  AMD: ENABLE_LAYER_MESA_ANTI_LAG=1 PROTON_FSR4_UPGRADE=1 game-performance %command%"
info "[GAMING] Steam/Proton: set \`proton-cachyos-slr\` and disable shader pre-caching options."
info "[GAMING] Lutris/Heroic: enable 'Disable Lutris Runtime' + 'Prefer system libraries', and use \`proton-cachyos\`."
info "More info: https://wiki.cachyos.org/configuration/gaming"
{{- end }}
