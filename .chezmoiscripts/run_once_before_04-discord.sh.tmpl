#!/bin/bash
set -euo pipefail

{{ template "utils.sh.tmpl" . }}
{{ template "external_links.sh.tmpl" . }}

echo ""
info "👾 [Discord Setup] Starting..."
echo ""

info "👾 Installing Discord (Equicord + OpenAsar) from AUR..."
paru -S --needed --noconfirm discord equicord-installer-bin

sudo Equilotl -install -location /opt/discord || success "Equicord already installed, skipping..."
sudo Equilotl -install-openasar -location /opt/discord || success "OpenAsar already installed, skipping..."

paru -Rns --noconfirm equicord-installer-bin || true

echo ""
success "✅ [Discord Setup] Done."
echo ""