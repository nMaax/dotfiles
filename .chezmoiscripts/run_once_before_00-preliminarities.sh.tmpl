#!/bin/bash

# For the future: move to shelly when it becomes default in CachyOS
# TODO: use color coded messages

set -euo pipefail

# --- Color Definitions ---
GREEN='\033[0;32m'
BLUE='\033[0;34m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
NC='\033[0m' # No Color

# --- Helper Logging Functions ---
info() { echo -e "${BLUE}==>${NC} $1"; }
success() { echo -e "${GREEN}==>${NC} $1"; }
warn() { echo -e "${YELLOW}==>${NC} $1"; }
error() { echo -e "${RED}==>${NC} $1"; }

{{- if ne .chezmoi.osRelease.id "cachyos" }}
echo "This script is intended to run on CachyOS."
echo "Did nothing, will close now."
exit 1
{{- end }}

echo ""
info "🧰 [Stage 0] Checking preliminarities..."
echo ""

read -rp "Did you tweak CachyOS as you like? [Y/n] " answer
if [[ "${answer,,}" != "y" && -n "$answer" ]]; then
  error "Go back and tune whatever you like using Cachy Hello. Closing, come back later."
  exit 1
fi

read -rp "Did you place the chezmoi.toml and the KeePass keyfile? [Y/n] " answer
if [[ "${answer,,}" != "y" && -n "$answer" ]]; then
  error "Please place the chezmoi.toml and KeePass keyfile in their proper locations before proceeding. Closing, come back later."
  exit 1
fi

info "🔄 Checking for cachy-update..."
if sudo pacman -Q cachy-update &>/dev/null; then
  cachy-update
else
  warning "cachy-update is not installed."
  warning "Did you really listen to me before??"
  warning "Please open 'CachyOS Hello' to enable cachy-update, and remind to tweak your system!"
fi

if [ -f /etc/default/grub ] && command -v grub-mkconfig >/dev/null; then
  info "==> Sanitizing GRUB to plain console (removing CachyOS theme)..."
  sudo sed -i "s|^GRUB_THEME=|#GRUB_THEME=|g" /etc/default/grub
  sudo sed -i "s|^#GRUB_TERMINAL_OUTPUT=console|GRUB_TERMINAL_OUTPUT=console|g" /etc/default/grub
  sudo grub-mkconfig -o /boot/grub/grub.cfg
fi

info "==> Checking for missing base packages..."
BASE_PACKAGES=(binutils base-devel git vim appmenu-gtk-module libdbusmenu-glib hyperland xdg-desktop-portal-hyprland chezmoi)
for pkg in "${BASE_PACKAGES[@]}"; do
  if ! pacman -Qi "$pkg" &>/dev/null; then
    info "    Installing missing package: $pkg"
    sudo pacman -S --needed --noconfirm "$pkg"
  fi
done

info "==> Installing other utilities..."
sudo pacman -S --needed --noconfirm smartmontools ffmpeg imagemagick glow dust bat ripgrep fd btop nvtop trash-cli ghostscript pandoc poppler qpdf
paru -S --needed --noconfirm caligula-bin pdfcpu-bin ocrmypdf tesseract-data-eng tesseract-data-ita

info "==> Setting Wireless Regdom to Italy"
sudo sed -i 's/^WIRELESS_REGDOM=/#&/' /etc/conf.d/wireless-regdom && sudo sed -i '/WIRELESS_REGDOM="IT"/s/^#//' /etc/conf.d/wireless-regdom

info "==> Update TLDR;"
tldr --update

info "==> Enable smartmontools to check for SSD health"
sudo systemctl enable --now smartd
sleep 2

info "==> Setup Uncomplicated Firewall"
sudo ufw enable
sleep 2

info "==> Enable SSH daemon"
sudo systemctl enable --now sshd
sleep 2

info "==> Installing MEGAcmd and KeePassXC"
paru -S --needed --noconfirm megacmd-bin
sudo pacman -S --needed --noconfirm keepassxc

info "==> Enabling MEGA"
if ! mega-whoami >/dev/null 2>&1; then
  info "You are not logged into MEGA. Loggin in now..."
  mega-login
else
  success "Already logged in to MEGA."
fi

info "==> Checking MEGA is synced with cloud..."
if ! mega-sync | grep "Synced"; then
  info "Mega is not synced. Syncing now."
  mkdir -p ~/MEGA
  mega-sync ~/MEGA/ /
  while ! mega-sync | grep -q "Synced"; do
    info "Still syncing... please wait."
    sleep 3
  done
  success "MEGA successfully synced."
else
  success "Mega is already synced."
fi

info "Mega synced with specifications:"
mega-sync

info "Issues with MEGA:"
mega-sync-issues

if ! ls ~/MEGA/KeePassXC/Password.kdbx &>/dev/null; then
  error "Couldn't find the KeePassXC database, maybe MEGA didn't download it."
  error "Can't proceed, will close now. This script is idempotent so you can run it again and resume where left."
  exit 1
fi

echo ""
success "✅ [Stage 0] Preliminarities checked and (eventually) fixed."
echo ""

warning -e "Please ensure your KeePass database is available and place your keyfile in the correct location.\nPress [Enter] to continue once you are ready..."
read -r
