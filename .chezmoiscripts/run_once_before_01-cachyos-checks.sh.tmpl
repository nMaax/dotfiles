#!/bin/bash
set -euo pipefail

{{ template "utils.sh.tmpl" . }}
{{ template "external_links.sh.tmpl" . }}

# For the future: move to shelly when it becomes default in CachyOS

{{- if ne .chezmoi.osRelease.id "cachyos" }}
error "This script is intended to run on CachyOS. But you are running it on $(
  . /etc/os-release
  echo "$NAME $VERSION"
)."
error "Please, use 🥮 dotfiles on CachyOS only."
exit 1
{{- end }}

echo ""
info "📦 [Checks & Prerequisites] Starting..."
echo ""

if ! ask "⚠️  This is an interactive install — you will need to respond to prompts throughout. Are you ready to proceed?"; then
  error "Come back when you are ready. Closing."
  exit 1
fi

if ! ask "Have you run a full system update before starting this installation?"; then
  error "A full system update is required before installation to prevent package conflicts or dependency resolution failure. Run cachy-update or paru -Syu"
  exit 1
fi

if ! ask "Did you place the chezmoi.toml at ~/.config/chezmoi/?"; then
  error "Please place the chezmoi.toml in its proper location before proceeding. Closing, come back later."
  exit 1
fi

{{ if .gaming -}}
info "🎮 gaming = true detected, ensuring CachyOS gaming packages are installed..."
if ! sudo pacman -S --needed --noconfirm cachyos-gaming-meta cachyos-gaming-applications; then
  error "Failed to install CachyOS gaming packages. Please resolve the pacman issue and re-run. Closing."
  exit 1
fi
success "✅ CachyOS gaming packages are now installed."
{{- end }}

info "📁 Creating home directories..."
mkdir -p "$HOME/Work"
xdg-user-dirs-update

info "📦 Checking for missing base packages..."
BASE_PACKAGES=(binutils base-devel git vim cmake cpio appmenu-gtk-module libdbusmenu-glib)
for pkg in "${BASE_PACKAGES[@]}"; do
  if ! pacman -Qi "$pkg" &>/dev/null; then
    info "    Installing missing package: $pkg"
    sudo pacman -S --needed --noconfirm "$pkg"
  fi
done

info "🔧 Installing other utilities..."
sudo pacman -S --needed --noconfirm curl zip 7zip sshfs caligula smartmontools grim slurp wl-clipboard ffmpeg resvg imagemagick perl-image-exiftool gifski zbar jq tesseract texlive-latex glow dust bat ripgrep fd btop fastfetch nvtop trash-cli transmission-cli ghostscript poppler qpdf ufw tealdeer ksshaskpass fzf zoxide translate-shell
paru -S --needed --noconfirm pdfcpu-bin ocrmypdf tesseract-data-eng tesseract-data-ita pandoc-bin

info "🖥️ Installing KDE suite, Qt, GTK and utility apps..."
paru -S --needed --noconfirm qt6ct-kde qt5ct-kde
sudo pacman -S --needed --noconfirm \
  adw-gtk-theme nwg-look \
  qt6-multimedia archlinux-xdg-menu ark dolphin-plugins filelight \
  okular haruna kwrite gwenview \
  kwallet kwalletmanager kwallet-pam
warn "[KWALLET] When prompted, create wallet 'kdewallet' with Blowfish and use your user password for auto-unlock."
info "More info: https://wiki.archlinux.org/title/KDE_Wallet"
info "Electron safe storage: https://www.electronjs.org/docs/latest/api/safe-storage"

GIT_NAME={{ .name | quote }}
GIT_EMAIL={{ .email | quote }}

info "🐙 Setting Git identity from config..."
git config --global user.name "$GIT_NAME"
git config --global user.email "$GIT_EMAIL"
info "Git identity set: $GIT_NAME <$GIT_EMAIL>"

echo ""
success "✅ [CachyOS Checks & Prerequisites] Done."
echo ""
