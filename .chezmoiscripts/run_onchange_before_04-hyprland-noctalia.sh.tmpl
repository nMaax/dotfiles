#!/bin/bash
set -euo pipefail

{{ template "utils.sh.tmpl" . }}
{{ template "external_links.sh.tmpl" . }}

echo ""
info "🌙 [Hyprland & Noctalia] Starting..."
echo ""

info "💧 Installing Hyprland core..."
sudo pacman -S --needed --noconfirm hyprland xdg-desktop-portal-hyprland

info "🌙 Installing Noctalia dependencies..."
sudo pacman -S --needed --noconfirm ddcutil
warn "[NOCTALIA] ddcutil may cause instability on some monitors; remove it if needed with: sudo pacman -Rns ddcutil"
paru -S --needed --noconfirm cliphist wlsunset xdg-desktop-portal evolution-data-server hyprshot

info "🦉 Installing Noctalia..."
paru -S --needed --noconfirm noctalia-shell
info "[NOCTALIA] Built-in app theming is pre-enabled for common apps."
info "Remaining app-specific steps: https://docs.noctalia.dev/theming/basic-app-theming/"

info "🔍 Installing Quickshell Overview..."
paru -S --needed --noconfirm quickshell-overview-git

info "🩸 Setting hyprland plugins..."
if ! hyprpm list | grep -q hyprland-scroll-overview; then
  hyprpm add https://github.com/yayuuu/hyprland-scroll-overview.git
  hyprpm update
  hyprpm enable scrolloverview
else
  success "hyprland-scroll-overview plugin already installed and enabled, skipping."
fi

info "🖼️ Installing mpvpaper for Video Wallpaper alternative backend..."
paru -S --needed --noconfirm mpvpaper

info "🀄 Syncing GTK with Noctalia and removing decorations..."
gsettings set org.gnome.desktop.interface gtk-theme 'adw-gtk3'
gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark'
gsettings set org.gnome.desktop.wm.preferences button-layout ':'

echo ""
success "✅ [Hyprland & Noctalia] Done."
echo ""
