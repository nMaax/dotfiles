#!/bin/bash
set -euo pipefail

{{ template "utils.sh.tmpl" . }}
{{ template "external_links.sh.tmpl" . }}

{{- if ne .chezmoi.osRelease.id "cachyos" }}
echo "This script is intended to run on CachyOS."
echo "Did nothing, will close now."
exit 1
{{- end }}

echo ""
info "🎨 [Stage 3] QoL tweaks..."
echo ""

info "🛜 Setting Wireless Regdom to Italy"
sudo sed -i 's/^WIRELESS_REGDOM=/#&/' /etc/conf.d/wireless-regdom && sudo sed -i '/WIRELESS_REGDOM="IT"/s/^#//' /etc/conf.d/wireless-regdom

info "📝 Update TLDR;"
tldr --update

info "💾 Enable smartmontools to check for SSD health"
sudo systemctl enable --now smartd
sleep 2

info "🧱 Setup Uncomplicated Firewall"
sudo ufw enable
sleep 2

info "🔐 Enable SSH daemon"
sudo systemctl enable --now sshd
sleep 2

info "🔑 Enable ssh-agent systemd user service"
systemctl --user enable --now ssh-agent
sleep 2

if [ -f /etc/default/grub ] && command -v grub-mkconfig >/dev/null; then
  info "📄 Sanitizing GRUB to plain console (removing CachyOS theme)..."
  grub_changed=0
  if grep -q "^GRUB_THEME=" /etc/default/grub; then
    sudo sed -i "s|^GRUB_THEME=|#GRUB_THEME=|g" /etc/default/grub
    grub_changed=1
  fi
  if grep -q "^#GRUB_TERMINAL_OUTPUT=console" /etc/default/grub; then
    sudo sed -i "s|^#GRUB_TERMINAL_OUTPUT=console|GRUB_TERMINAL_OUTPUT=console|g" /etc/default/grub
    grub_changed=1
  fi
  if [ "$grub_changed" -eq 1 ]; then
    sudo grub-mkconfig -o /boot/grub/grub.cfg
  else
    success "GRUB already sanitized. Skipping grub-mkconfig."
  fi
fi

info "🔐 Patching PAM for KWallet auto-unlock at login (all configurations)..."
# On CachyOS/Arch, installing any KDE6 app (KWallet, Dolphin, …) brings in kf6-kwallet
# which ships ksecretd instead of the old kwalletd5. pam_kwallet5.so must therefore
# explicitly point to ksecretd — this applies regardless of whether you run full Plasma
# or individual KDE apps inside Hyprland (or any other WM).
#
# Without the kwalletd= parameter, pam_kwallet5.so tries to start the absent kwalletd5
# daemon and auto-unlock silently fails.
#
# We handle every combination of LUKS encryption and SDDM autologin:
#
#   Standard login (no autologin), ±LUKS  → patch /etc/pam.d/sddm
#   Autologin without LUKS                → patch /etc/pam.d/sddm-autologin (kwallet5 only)
#   Autologin with LUKS                   → patch /etc/pam.d/sddm-autologin (loadkey + kwallet5)
#                                           + create KeyringMode=inherit systemd drop-in
#
# See: https://wiki.archlinux.org/title/KDE_Wallet#Configure_PAM_on_Plasma_6_(KF6)
# See: https://wiki.archlinux.org/title/KDE_Wallet#Using_SDDM_autologin_and_LUKS_encryption

# --- SDDM login (covers ±LUKS) ---
if [ ! -f /etc/pam.d/sddm ]; then
  warn "/etc/pam.d/sddm not found. Skipping KWallet SDDM PAM patch."
elif grep -q "kwalletd=/usr/bin/ksecretd" /etc/pam.d/sddm; then
  success "/etc/pam.d/sddm already contains kwalletd parameter. Skipping."
else
  sudo sed -i 's/\(pam_kwallet5\.so auto_start\)\($\| \)/\1 kwalletd=\/usr\/bin\/ksecretd\2/' /etc/pam.d/sddm
  success "Added kwalletd=/usr/bin/ksecretd to /etc/pam.d/sddm"
fi

# --- SDDM autologin (present only when the user enabled autologin) ---
if [ ! -f /etc/pam.d/sddm-autologin ]; then
  warn "No /etc/pam.d/sddm-autologin found — SDDM autologin not configured. Skipping autologin KWallet patch."
elif grep -q "pam_kwallet5\.so.*kwalletd=/usr/bin/ksecretd" /etc/pam.d/sddm-autologin; then
  success "/etc/pam.d/sddm-autologin already patched for KWallet. Skipping."
else
  if lsblk -rno TYPE 2>/dev/null | grep -q "^crypt$" || [ -s /etc/crypttab ]; then
    # --- Autologin with LUKS ---
    info "Autologin + LUKS detected — adding pam_systemd_loadkey + pam_kwallet5 to sddm-autologin..."

    # pam_systemd_loadkey passes the LUKS passphrase from the kernel keyring so that
    # pam_kwallet5 can unlock the wallet without a second interactive prompt.
    sudo tee -a /etc/pam.d/sddm-autologin >/dev/null <<'PAM_EOF'
-auth       optional    pam_systemd_loadkey.so
-auth       optional    pam_kwallet5.so
-session    optional    pam_kwallet5.so auto_start kwalletd=/usr/bin/ksecretd
PAM_EOF

    # SDDM must inherit the kernel keyring populated by the bootloader at LUKS unlock time.
    SDDM_DROP_IN="/etc/systemd/system/sddm.service.d/keyringmode.conf"
    if [ -f "$SDDM_DROP_IN" ] && grep -q "KeyringMode=inherit" "$SDDM_DROP_IN"; then
      success "SDDM KeyringMode drop-in already present. Skipping."
    else
      sudo mkdir -p "$(dirname "$SDDM_DROP_IN")"
      sudo tee "$SDDM_DROP_IN" >/dev/null <<'DROPIN_EOF'
[Service]
KeyringMode=inherit
DROPIN_EOF
      sudo systemctl daemon-reload
      success "Created SDDM KeyringMode=inherit drop-in at $SDDM_DROP_IN"
    fi
  else
    # --- Autologin without LUKS ---
    info "Autologin without LUKS detected — adding pam_kwallet5 to sddm-autologin..."
    sudo tee -a /etc/pam.d/sddm-autologin >/dev/null <<'PAM_EOF'
-auth       optional    pam_kwallet5.so
-session    optional    pam_kwallet5.so auto_start kwalletd=/usr/bin/ksecretd
PAM_EOF
  fi
  success "KWallet PAM entries added to /etc/pam.d/sddm-autologin"
fi

info "🖥️ Setting up Silent SDDM Themes..."

sddm_configured=0

if ! pacman -Qs sddm-silent-theme >/dev/null; then
  info "Installing sddm-silent-theme..."
  paru -S --needed --noconfirm sddm-silent-theme
  sddm_configured=1
fi

if grep -q "Current=silent" /etc/sddm.conf 2>/dev/null; then
  success "/etc/sddm.conf is already configured for the silent theme. Skipping..."
else
  info "Appending configuration to /etc/sddm.conf..."
  sudo tee -a /etc/sddm.conf >/dev/null <<'EOF'

[General]
InputMethod=qtvirtualkeyboard
GreeterEnvironment=QML2_IMPORT_PATH=/usr/share/sddm/themes/silent/components/,QT_IM_MODULE=qtvirtualkeyboard

[Theme]
Current=silent
EOF
  sddm_configured=1
fi

SILENT_SDDM_EXT_THEMES_DIR="$HOME/.cache/silent-sddm-themes"
SILENT_SDDM_DIR="/usr/share/sddm/themes/silent"
AVATAR_SCRIPT="$SILENT_SDDM_DIR/change_avatar.sh"
USER_FACE="$HOME/.face"

if [ -d "$SILENT_SDDM_EXT_THEMES_DIR" ]; then
  info "Deploying custom SDDM theme overlay..."
  sudo cp -r "$SILENT_SDDM_EXT_THEMES_DIR/"* "$SILENT_SDDM_DIR/"
  success "SDDM custom themes deployed."
fi

if [ -f "$USER_FACE" ]; then
  sudo chmod +x "$AVATAR_SCRIPT"
  sudo "$AVATAR_SCRIPT" "$(whoami)" "$USER_FACE"
  success "Avatar updated successfully."
else
  warn "$USER_FACE not found. Skipping avatar change."
fi

if [ "$sddm_configured" -eq 1 ]; then
  add_note "[SDDM] Remind to select systemd owned Hyprland at login in SDDM, in order to enable specific autostarts to work."
  add_note "[SDDM] Remind to run ./test.sh in $SILENT_SDDM_DIR to check SDDM works and you are not kept out of your system at next boot."
fi

info "🖱️ Setting up MCHOSE udev rules..."
UDEV_RULE_PATH="/etc/udev/rules.d/99-mchose.rules"
UDEV_RULE_TMP="$(mktemp)"

cat >"$UDEV_RULE_TMP" <<'EOF'
# MCHOSE Ace 68 Turbo 16K (Keyboard)
KERNEL=="hidraw*", ATTRS{idVendor}=="3837", ATTRS{idProduct}=="3026", MODE="0666"
SUBSYSTEM=="usb", ATTRS{idVendor}=="3837", ATTRS{idProduct}=="3026", MODE="0666"

# MCHOSE L7 Pro+ (Mouse Wired)
KERNEL=="hidraw*", ATTRS{idVendor}=="3837", ATTRS{idProduct}=="4015", MODE="0666"
SUBSYSTEM=="usb", ATTRS{idVendor}=="3837", ATTRS{idProduct}=="4015", MODE="0666"

# MCHOSE L7 Pro+ (Mouse Wireless Receiver)
KERNEL=="hidraw*", ATTRS{idVendor}=="5253", ATTRS{idProduct}=="1020", MODE="0666"
SUBSYSTEM=="usb", ATTRS{idVendor}=="5253", ATTRS{idProduct}=="1020", MODE="0666"
EOF

if [ ! -f "$UDEV_RULE_PATH" ] || ! cmp -s "$UDEV_RULE_TMP" "$UDEV_RULE_PATH"; then
  sudo cp "$UDEV_RULE_TMP" "$UDEV_RULE_PATH"
  sudo chmod 644 "$UDEV_RULE_PATH"
  sudo udevadm control --reload-rules
  sudo udevadm trigger
  success "MCHOSE udev rules installed"
else
  info "MCHOSE udev rules already present"
fi

rm -f "$UDEV_RULE_TMP"

info "Downloading EasyEffects Community Presets... (⚠️ not really the Arch way, but it doesnt touch anything outside home/)"
if [ -z "$(ls -A "$HOME/.config/easyeffects/db/" 2>/dev/null)" ]; then
  bash <(curl -fsSL "$EASYEFFECTS_PRESETS_INSTALL_URL")
else
  success "EasyEffects Presets already installed, skipping."
fi

info "🍚 Installing ricing commands..."
sudo pacman -S --needed --noconfirm cowsay lolcat cmatrix cava fastfetch btop figlet fortune-mod
paru -S --needed --noconfirm nyancat pipes.sh tty-clock cbonsai

{{ if .gaming -}}
success "🎮 Gaming flag is set. Applying optimizations..."

info "🛸 Installing Millennium..."
paru -S --needed --noconfirm millennium

info "⛏️ Installing Minecraft (Prism-launcher and Java dependencies)..."
sudo pacman -S --needed --noconfirm prismlauncher
sudo pacman -S --needed --noconfirm jdk8-openjdk jdk17-openjdk jdk21-openjdk

info "🥭 Installing mango and mangojuice..."
sudo pacman -S --needed --noconfirm mangohud
paru -S --needed --noconfirm mangojuice

if pacman -Q gamemode >/dev/null 2>&1; then
  info "Feral's gamemode detected. Checking for ananicy-cpp conflicts..."
  if systemctl is-enabled --quiet ananicy-cpp 2>/dev/null || systemctl is-active --quiet ananicy-cpp 2>/dev/null; then
    warn "Conflict detected: Disabling ananicy-cpp to prevent GameMode scheduling issues..."
    sudo systemctl disable --now ananicy-cpp
  else
    info "ananicy-cpp is not active. No conflicts."
  fi
else
  info "Feral's gamemode not installed. Skipping ananicy-cpp conflict check."
fi

add_note "[GAMING] 🖥️ Shader cache is configured via chezmoi (~/.config/environment.d/gaming.conf). Re-run chezmoi apply if you change the gpu_vendor variable."

add_note "[GAMING] 🖱️ Mouse acceleration profile for gaming is set to 'flat' (no acceleration) via the Hyprland input config (~/.config/hypr/hyprland/input.conf). Update the 'name' field there with the exact device name from \`hyprctl devices\`."

add_note "[GAMING]:

  🚀 STEAM LAUNCH OPTIONS
  For NVIDIA:
      PROTON_ENABLE_WAYLAND=1 PROTON_DLSS_UPGRADE=1 PROTON_NVIDIA_LIBS_NO_32BIT=1 PROTON_USE_NTSYNC=1 PROTON_ENABLE_HDR=1 ENABLE_HDR_WSI=1 game-performance %command%
  For AMD:
      PROTON_USE_NTSYNC=1 ENABLE_LAYER_MESA_ANTI_LAG=1 PROTON_FSR4_UPGRADE=1 game-performance %command%

  ⚙️  PROTON / STEAM SETTINGS
  - Compatibility: Set \`proton-cachyos-slr\` as your default Proton layer.
  - Pre-caching: If using Proton-CachyOS, go to Steam -> Settings -> Downloads and UNCHECK 
    \"Enable Shader Pre-caching\" and \"Allow background processing of Vulkan shaders\".

  🍷 LUTRIS / HEROIC SETTINGS
  - Under System Options, enable \"Disable Lutris Runtime\" and \"Prefer system libraries\".
  - Make sure the compatibility layer is set to \`proton-cachyos\`.
  - Set launch options similarly as done in steam (see documentation)

  For more information, check https://wiki.cachyos.org/configuration/gaming"

{{- end }}

echo "🌐 Installing Tailscale..."
sudo pacman -S --noconfirm --needed tailscale

echo "🌐 Enabling Tailscale daemon..."
sudo systemctl enable --now tailscaled
sleep 2

{{- if .tailscale_authkey }}
echo "🔑 Authenticating Tailscale using provided authkey..."
if sudo tailscale status 2>/dev/null | grep -qE "^[0-9]+\.[0-9]"; then
  echo "✅ Tailscale already connected. Skipping."
else
  sudo tailscale up --ssh --authkey="{{ .tailscale_authkey }}"
  echo "✅ Tailscale connected successfully."
fi
{{- else }}
echo "⚠️ No 'tailscale_authkey' found in chezmoi.toml. Skipping auto-login."
{{- end }}

echo "🏔️ Installing NordVPN from AUR..."
paru -S --noconfirm --needed nordvpn-bin

echo "🛡️ Enabling NordVPN daemon..."
sudo systemctl enable --now nordvpnd
sudo usermod -aG nordvpn "$USER"
sleep 2
add_note "[NORDVPN]: Remind to reboot your system to use NordVPN"

{{- if .nordvpn_token }}
echo "🔑 Logging into NordVPN using provided token..."
if ! sg nordvpn -c "nordvpn account" &>/dev/null; then
  sg nordvpn -c "nordvpn login --token {{ .nordvpn_token }}"
else
  echo "✅ Already logged into NordVPN. Skipping login."
fi

# Proceed with settings configuration
if sg nordvpn -c "nordvpn status" | grep -E -q "Status: (Connected|Disconnected)"; then
  sg nordvpn -c "nordvpn set dns off"
  sg nordvpn -c "nordvpn set threatprotection off"
  sg nordvpn -c "nordvpn set post-quantum on"
  sg nordvpn -c "nordvpn set firewall on"
  echo "✅ NordVPN configured successfully."
fi
{{- else }}
echo "⚠️ No 'nordvpn_token' found in chezmoi.toml. Skipping auto-login."
{{- end }}

echo ""
success "✅ [Stage 3] Apps and tweaks applied."
echo ""

# ==========================================
# FINAL SUMMARY
# ==========================================
echo ""
echo -e "${GREEN}=================================================================${NC}"
echo -e "${GREEN}🎉 DOTFILES INSTALLATION COMPLETE! PLEASE READ THESE POST-INSTALL STEPS:${NC}"
echo -e "${GREEN}=================================================================${NC}"
echo ""
show_notes
