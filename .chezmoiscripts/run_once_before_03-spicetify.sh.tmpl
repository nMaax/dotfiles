#!/bin/bash
set -euo pipefail

{{ template "utils.sh.tmpl" . }}

SPICETIFY_SETUP_SCRIPT="{{ .chezmoi.homeDir }}/.local/bin/spicetify-setup.sh"

if [[ ! -f "$SPICETIFY_SETUP_SCRIPT" ]]; then
  SPICETIFY_SETUP_SCRIPT="{{ .chezmoi.sourceDir }}/dot_local/bin/executable_spicetify-setup.sh"
fi

if [[ ! -f "$SPICETIFY_SETUP_SCRIPT" ]]; then
  error "Missing Spicetify setup script at $SPICETIFY_SETUP_SCRIPT"
  exit 1
fi

echo ""
info "🎧 [Spotify & Spicetify] Starting..."
echo ""

bash "$SPICETIFY_SETUP_SCRIPT"

echo ""
success "✅ [Spotify & Spicetify] Done."
echo ""
