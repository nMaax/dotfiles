#!/bin/bash
set -euo pipefail

{{ template "utils.sh.tmpl" . }}

echo ""
info "🌐 [Installing Webapps] Starting..."
echo ""

info "♊ Installing Gemini Webapp..."
~/.local/bin/install-webapp "Gemini" "https://gemini.google.com/app"

info "🤖 Installing Copilot Webapp..."
install-webapp "Copilot" "https://github.com/copilot" "https://cdn.jsdelivr.net/gh/homarr-labs/dashboard-icons/png/github-copilot.png"

info "🖱️ Installing MCHOOSE HUB Webapp..."
.local/bin/install-webapp "MCHOSE HUB" "https://www.mchose.com.cn/#/connectDevice"

echo ""
success "✅ [Installing Webapps] Done."
echo ""
