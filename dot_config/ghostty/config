# This is the configuration file for Ghostty.
#
# Run `ghostty +show-config --default --docs` to view a list of all available
# config options and their default values. Each option is also documented at
# https://ghostty.org/docs/config.
#
# Ghostty can reload the configuration while running via the menu or the bound
# key (default: Control + Shift + comma). Not all options can be reloaded at
# runtime; some only apply to new windows and others require a full restart.

# Vertical padding (top/bottom)
window-padding-y = 10

# Horizontal padding (left/right)
window-padding-x = 12

# Optional: ensure the background color fills the padding
window-padding-balance = true

custom-shader = shaders/cursor_warp.glsl
theme = noctalia
